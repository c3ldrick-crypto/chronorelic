// Prisma Schema — ChronoRelic v2 (simplified)
// Prisma v7 — provider: prisma-client

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  GUEST
  FREE
  PREMIUM
  ADMIN
}

enum CharacterClass {
  CHRONOMANCER
  ARCHIVISTE
  CHASSEUR
  ORACLE
}

enum Rarity {
  COMMUNE
  RARE
  EPIQUE
  LEGENDAIRE
  MYTHIQUE
}

enum ChronolitheStatus {
  IN_PROGRESS
  COMPLETED
}

enum PurchaseType {
  PREMIUM_UNLOCK
  SHARDS_STARTER
  SHARDS_AVENTURIER
  SHARDS_LEGENDAIRE
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  image          String?
  passwordHash   String?
  role           Role      @default(FREE)
  isPremium      Boolean   @default(false)
  premiumAt      DateTime?
  temporalShards Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  character            Character?
  relics               Relic[]
  purchases            Purchase[]
  streakData           StreakData?
  sessions             UserSession[]
  auditLogs            AuditLog[]
  questClaims          QuestClaim[]
  chronolitheProgress  ChronolitheProgress[]
  heroRelicProgress    HeroRelicProgress[]

  @@index([email])
}

// ─────────────────────────────────────────────
// SESSION
// ─────────────────────────────────────────────

model UserSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

// ─────────────────────────────────────────────
// CHARACTER
// ─────────────────────────────────────────────

model Character {
  id        String         @id @default(cuid())
  userId    String         @unique
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  class     CharacterClass
  level     Int            @default(1)
  xp        Int            @default(0)
  xpTotal   Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([userId])
}

// ─────────────────────────────────────────────
// RELIQUE
// ─────────────────────────────────────────────

model Relic {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  minute          String
  captureDate     String           @default("")
  rarity          Rarity
  xpGained        Int
  historicalEventId String?
  historicalEvent   HistoricalEvent? @relation(fields: [historicalEventId], references: [id])
  capturedAt      DateTime         @default(now())

  @@unique([userId, captureDate, minute])
  @@index([userId])
  @@index([captureDate])
  @@index([rarity])
}

// ─────────────────────────────────────────────
// EVENEMENT HISTORIQUE
// ─────────────────────────────────────────────

model HistoricalEvent {
  id          String   @id @default(cuid())
  minute      String
  year        Int?
  title       String
  description String
  curiosity   String?
  category    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  relics Relic[]

  @@index([minute])
}

// ─────────────────────────────────────────────
// STREAK & COMBO
// ─────────────────────────────────────────────

model StreakData {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStreak Int       @default(0)
  longestStreak Int       @default(0)
  lastPlayedAt  DateTime?
  comboCount    Int       @default(0)
  updatedAt     DateTime  @updatedAt
}

// ─────────────────────────────────────────────
// ACHAT (Stripe)
// ─────────────────────────────────────────────

model Purchase {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  stripeId      String       @unique
  type          PurchaseType
  amountCents   Int
  currency      String       @default("eur")
  shardsGranted Int          @default(0)
  status        String       @default("completed")
  createdAt     DateTime     @default(now())

  @@index([userId])
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  resource  String?
  details   Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([action])
}

// ─────────────────────────────────────────────
// QUÊTES / CHAÎNES
// ─────────────────────────────────────────────

model QuestClaim {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questId   String
  claimedAt DateTime @default(now())

  @@unique([userId, questId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// CHRONOLITHES (histoires fragmentées du passé)
// ─────────────────────────────────────────────

model ChronolitheProgress {
  id               String            @id @default(cuid())
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  storyId          String
  unlockedSegments Int               @default(1)
  status           ChronolitheStatus @default(IN_PROGRESS)
  startedAt        DateTime          @default(now())
  completedAt      DateTime?
  updatedAt        DateTime          @updatedAt

  @@unique([userId, storyId])
  @@index([userId])
  @@index([userId, status])
}

// ─────────────────────────────────────────────
// HERO RELIC (aventures branchées)
// ─────────────────────────────────────────────

enum HeroStatus {
  IN_PROGRESS
  COMPLETED
  DEAD
}

enum HeroEndType {
  HISTORICAL
  ALTERNATE
}

model HeroRelicProgress {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  storyId        String
  currentSegment String       @default("start")
  choicesPath    Json         @default("[]")
  status         HeroStatus   @default(IN_PROGRESS)
  endType        HeroEndType?
  startedAt      DateTime     @default(now())
  completedAt    DateTime?
  updatedAt      DateTime     @updatedAt

  @@unique([userId, storyId])
  @@index([userId])
  @@index([userId, status])
}

// ─────────────────────────────────────────────
// BETA WAITLIST
// ─────────────────────────────────────────────

model BetaSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  source    String   @default("landing")
  note      String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}
